---
/**
 * Project Card Component
 * Renders individual project data fetched from the Astro Content Collection.
 * Enforces strict typing based on the 'projects' schema.
 */
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, description, techStack, liveUrl, githubUrl, isPrivateRepo } = project.data;
---

<article class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col h-full group">
  <header class="mb-4">
    <h3 class="text-xl font-bold text-zinc-900 dark:text-zinc-100 group-hover:text-brand dark:group-hover:text-brand-dark transition-colors">
      {title}
    </h3>
  </header>
  
  <div class="flex-grow">
    <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-6">
      {description}
    </p>
    
    <ul class="flex flex-wrap gap-2 mb-6" aria-label="Tecnologías utilizadas">
      {techStack.map((tech) => (
        <li class="px-2.5 py-1 bg-zinc-100 dark:bg-zinc-950 text-zinc-700 dark:text-zinc-300 rounded-md text-xs font-mono border border-zinc-200 dark:border-zinc-800">
          {tech}
        </li>
      ))}
    </ul>
  </div>
  
  <footer class="flex items-center gap-4 pt-4 border-t border-zinc-100 dark:border-zinc-800 mt-auto">
    {liveUrl && (
      <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="text-brand dark:text-brand-dark hover:underline text-sm font-medium flex items-center gap-1">
        Demo en Vivo
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
      </a>
    )}
    
    {isPrivateRepo ? (
      <span class="text-zinc-400 dark:text-zinc-600 text-sm font-mono flex items-center gap-1 cursor-not-allowed select-none" title="El código fuente está protegido como activo comercial">
        // Repositorio Privado
      </span>
    ) : (
      githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 text-sm font-medium transition-colors">
          Código Fuente
        </a>
      )
    )}
  </footer>
</article>
---
/**
 * Contact Section Component
 * Handles asynchronous form submission via Netlify Forms and Fetch API.
 * Integration: Netlify Forms (Serverless)
 * * @see https://www.netlify.com/products/forms/
 */
---

<section id="contacto" class="max-w-5xl mx-auto px-6 py-24">
  <div class="bg-zinc-100 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-8 md:p-12 flex flex-col lg:flex-row gap-12">
    
    <div class="lg:w-1/2 flex flex-col justify-center">
      <h2 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-4">
        ¿Construimos algo juntos?
      </h2>
      <p class="text-zinc-600 dark:text-zinc-400 text-lg mb-8">
        Estoy disponible para nuevos desafíos, roles de ingeniería de software o consultorías de arquitectura backend.
      </p>
      
      <div class="flex gap-4">
        <a 
          href="https://www.linkedin.com/in/eddie-arango-b77783292" 
          target="_blank" 
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-200 dark:hover:bg-zinc-800 text-zinc-900 dark:text-zinc-100 font-medium transition-colors"
          aria-label="LinkedIn Profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="lg:w-1/2">
      <form 
        id="portfolio-form"
        name="portfolio-contact"
        method="POST" 
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="flex flex-col gap-4 relative"
      >
        <input type="hidden" name="form-name" value="portfolio-contact" />
        <p class="hidden">
          <label>Honeypot: <input name="bot-field" /></label>
        </p>

        <div>
          <label for="name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Nombre</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg bg-white dark:bg-zinc-950 border border-zinc-300 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand" />
        </div>
        
        <div>
          <label for="email" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Correo Electrónico</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg bg-white dark:bg-zinc-950 border border-zinc-300 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand" />
        </div>
        
        <div>
          <label for="message" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">Mensaje</label>
          <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-lg bg-white dark:bg-zinc-950 border border-zinc-300 dark:border-zinc-700 text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand resize-none"></textarea>
        </div>
        
        <button type="submit" id="submit-btn" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3 mt-2 rounded-lg bg-brand hover:bg-brand-dark text-white font-medium transition-colors disabled:opacity-70">
          <span id="btn-text">Enviar Mensaje</span>
        </button>

        <div id="form-success" class="hidden text-center text-sm font-medium text-green-600 mt-2">¡Éxito! Mensaje enviado.</div>
        <div id="form-error" class="hidden text-center text-sm font-medium text-red-600 mt-2">Error al enviar el mensaje.</div>
      </form>
    </div>
  </div>
</section>

<script>
  /**
   * AJAX Form Handler
   * Intercepts standard POST submission for background processing.
   */
  const form = document.getElementById('portfolio-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');
  const formSuccess = document.getElementById('form-success');
  const formError = document.getElementById('form-error');

  if (form && submitBtn && btnText) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const originalText = btnText.textContent;
      btnText.textContent = 'Sending...';
      submitBtn.setAttribute('disabled', 'true');

      const formData = new FormData(form as HTMLFormElement);
      const body = new URLSearchParams(formData as any).toString();

      fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body,
      })
      .then((res) => {
        if (!res.ok) throw new Error();
        (form as HTMLFormElement).reset();
        formSuccess?.classList.remove('hidden');
      })
      .catch(() => formError?.classList.remove('hidden'))
      .finally(() => {
        btnText.textContent = originalText;
        submitBtn.removeAttribute('disabled');
      });
    });
  }
</script>